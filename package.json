{
  "name": "cutdown-parser",
  "version": "0.3.6-rc.4",
  "description": "Cutdown markup language parser in TypeScript",
  "keywords": [
    "AST",
    "cutdown",
    "markdown",
    "parser"
  ],
  "homepage": "https://github.com/cuttie-app/cutdown-ts",
  "bugs": {
    "url": "https://github.com/cuttie-app/cutdown-ts/issues"
  },
  "license": "MIT",
  "author": "Cuttie App (https://github.com/cuttie-app)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuttie-app/cutdown-ts.git"
  },
  "funding": {
    "url": "https://github.com/sponsors/cuttie-app"
  },
  "bin": {
    "cutdown-parser": "dist/cutdown-parser.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup --config .config/tsup.config.ts",
    "prepublishOnly": "pnpm run build",
    "test": "vitest --config .config/vitest.config.ts run",
    "check:ts": "tsc --noEmit",
    "check:format": "oxfmt . -c .config/.oxfmtrc.json --check",
    "check:lint": "oxlint . -c .config/.oxlintrc.json",
    "format": "oxfmt . -c .config/.oxfmtrc.json --write"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.19.15",
    "js-yaml": "4.1.1",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.30.3"
}
