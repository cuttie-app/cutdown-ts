{
  "name": "cutdown-parser",
  "version": "0.0.1",
  "description": "Cutdown markup language parser in TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsup --config .config/tsup.config.ts",
    "check:lint": "oxlint . -c .config/.oxlintrc.json",
    "check:format": "oxfmt . -c .config/.oxfmtrc.json --check",
    "check:ts": "tsc --noEmit",
    "format": "oxfmt . -c .config/.oxfmtrc.json --write",
    "test": "vitest --config .config/vitest.config.ts run"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.19.15",
    "js-yaml": "4.1.1",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
